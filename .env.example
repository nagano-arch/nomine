# AWS Lambda環境変数サンプル
# 本番環境では AWS Secrets Manager または AWS Systems Manager Parameter Store の使用を推奨

# Node.js環境
NODE_ENV=production

# データベース設定（RDS PostgreSQL）
DB_HOST=your-rds-instance.xxxx.ap-northeast-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=nomine
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_SSL=true

# JWT認証設定
JWT_SECRET=your-very-secret-jwt-key-change-this-in-production
SESSION_EXPIRY_DAYS=7

# AWS S3設定
S3_BUCKET_NAME=nomine-uploads
AWS_REGION=ap-northeast-1

# CloudFront設定（オプション）
CLOUDFRONT_DOMAIN=dxxxxxxxxx.cloudfront.net

# AWS認証情報（Lambda実行ロールを使用する場合は不要）
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# アプリケーション設定
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,video/mp4,video/quicktime

# レート制限
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_MS=60000

# セキュリティ
BCRYPT_SALT_ROUNDS=10
